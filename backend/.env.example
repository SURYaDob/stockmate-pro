# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stockmate_pro?schema=public"

# JWT
JWT_ACCESS_SECRET="your-access-secret-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Redis (for session management)
REDIS_URL="redis://localhost:6379"

# Email (for OTP & password reset)
# ── Popular SMTP providers (free tiers available) ──
#
# 1. Brevo (brevo.com) — 300 emails/day free
#    Host: smtp-relay.brevo.com  Port: 587  TLS: yes
#
# 2. SendGrid (sendgrid.com) — 100 emails/day free
#    Host: smtp.sendgrid.net  Port: 587  User: apikey
#    Pass: your SendGrid API key
#
# 3. Gmail (requires App Password — https://myaccount.google.com/apppasswords)
#    Host: smtp.gmail.com  Port: 587  TLS: yes
#
# 4. Mailgun (mailgun.com) — 100 emails/day free
#    Host: smtp.mailgun.org  Port: 587  TLS: yes
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USER="your-smtp-email@example.com"
SMTP_PASS="your-smtp-password-or-api-key"
EMAIL_FROM="noreply@stockmatepro.com"

# App
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:5000"

# Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR="./uploads"

# GST
DEFAULT_GST_RATE=18
STATE_CODE="27" # Maharashtra

# Web Push (VAPID) - for browser push notifications
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_MAILTO="mailto:noreply@stockmatepro.com"
